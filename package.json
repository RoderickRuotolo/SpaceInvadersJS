{
  "name": "space-invaders-js",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"js/**/*.js\" \"tests/**/*.js\"",
    "format": "prettier --write \"js/**/*.js\" \"tests/**/*.js\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"js/**/*.js\" \"tests/**/*.js\" \"*.json\" \"*.md\""
  },
  "devDependencies": {
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "vitest": "^2.1.8"
  }
}
